http://{$APP_HOSTNAME}, http://laraowl-ws.urfysoft.uz {
        root * /usr/share/caddy/html/public

        header {
                # enable HSTS
                # Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

                # Enable cross-site filter (XSS) and tell browser to block detected attacks
                X-Xss-Protection "1; mode=block"

                # disable clients from sniffing the media type
                X-Content-Type-Options "nosniff"

                # clickjacking protection
                X-Frame-Options "SAMEORIGIN"

                Content-Security-Policy "upgrade-insecure-requests"

                # hide server name
                -Server Caddy
        }

        # Allow large file uploads
        request_body {
                max_size 100mb
        }

        # Serve storage files directly
        handle_path /storage/* {
                root * /usr/share/caddy/html/storage/app/public
                file_server
                header Cache-Control "public, max-age=31536000"
        }

        # Proxy Reverb WebSocket connection
        handle /app* {
                reverse_proxy reverb:8080
        }

        # Handle PHP files with FastCGI
        php_fastcgi app:9000
        file_server

        # Logging
        log {
                output stdout
                format console
        }
}

http://localhost {
        respond "OK" 200
}
